# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Required for scripts/seed.mjs only
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# AI
ANTHROPIC_API_KEY=your_anthropic_api_key

# Figma OAuth
FIGMA_CLIENT_ID=your_figma_client_id
FIGMA_CLIENT_SECRET=your_figma_client_secret

# Figma token encryption — AES-256-GCM key (required, never commit the real value)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FIGMA_TOKEN_ENCRYPTION_KEY=64_hex_chars_here

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=Lane <noreply@yourdomain.com>
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron security
CRON_SECRET=your_cron_secret

# Redis rate limiting (Upstash)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# Dev/test only — DO NOT set in Vercel production
# ENABLE_MULTI_ROLE_TESTING=true
