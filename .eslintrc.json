{
  "extends": ["next/core-web-vitals"],
  "rules": {
    "no-restricted-imports": [
      "warn",
      {
        "paths": [
          {
            "name": "@/db",
            "message": "Importing @/db bypasses Row Level Security. Prefer withUserDb / withUserSession from @/db/user for user-facing routes. If this file is a legitimate system-level caller (cron, background job, bootstrap flow), add its path to the allowlist in .eslintrc.json overrides. Tracked migration: see Issue #42."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "error",
      {
        "selector": "JSXOpeningElement[name.name='button']",
        "message": "Use <Button> from @/components/ui/button instead of raw <button>. Exception: color swatches with dynamic style."
      },
      {
        "selector": "JSXOpeningElement[name.name='input']",
        "message": "Use <Input> from @/components/ui/input instead of raw <input>."
      },
      {
        "selector": "JSXOpeningElement[name.name='textarea']",
        "message": "Use <Textarea> from @/components/ui/textarea instead of raw <textarea>."
      },
      {
        "selector": "JSXOpeningElement[name.name='select']",
        "message": "Use <NativeSelect> from @/components/ui/native-select instead of raw <select>."
      }
    ]
  },
  "overrides": [
    {
      "files": ["components/ui/**/*.tsx"],
      "rules": {
        "no-restricted-syntax": "off"
      }
    },
    {
      "files": [
        "app/api/cron/**",
        "app/views/**",
        "lib/ai/**",
        "lib/alerts/**",
        "lib/digest.ts",
        "lib/figma/sync.ts",
        "lib/analytics/**",
        "lib/onboarding/**",
        "lib/dashboard/**",
        "db/**",
        "scripts/**"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ]
}
