{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- ':(exclude)*.md' ':(exclude)docs/**' ':(exclude)04-specs/**' ':(exclude)TODO*.md' ':(exclude)deferred.md' ':(exclude)CHANGELOG.md' ':(exclude).github/**'",
  "crons": [
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 9 * * 5"
    },
    {
      "path": "/api/cron/alerts",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/morning-briefing",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/resurface",
      "schedule": "0 9 * * *"
    }
  ]
}
